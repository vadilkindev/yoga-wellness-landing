---
import '../styles/globals.css';
---
<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>Radha — Yoga, Meditación &amp; Life Coaching</title>
		<meta name="description" content="Yoga, Meditación y Life Coaching para cultivar una vida en equilibrio profundo y conexión consciente." />

		<!-- Preconnect Google Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Manrope:wght@300;400;500;600&display=swap"
			rel="stylesheet"
		/>
	</head>
	<body>
		<slot />

		<!-- Global scroll-reveal via IntersectionObserver -->
		<script>
			const revealEls = document.querySelectorAll<HTMLElement>('.reveal-up');

			// Skip hero elements — they animate via CSS keyframe immediately
			const toObserve = Array.from(revealEls).filter(
				el => !el.closest('#hero')
			);

			if ('IntersectionObserver' in window) {
				const io = new IntersectionObserver(
					(entries) => {
						entries.forEach(entry => {
							if (entry.isIntersecting) {
								(entry.target as HTMLElement).classList.add('visible');
								io.unobserve(entry.target);
							}
						});
					},
					{ threshold: 0.12 }
				);
				toObserve.forEach(el => io.observe(el));
			} else {
				// Fallback: show everything
				toObserve.forEach(el => el.classList.add('visible'));
			}
		</script>
	</body>
</html>

<style>
	html, body {
		margin: 0;
		width: 100%;
	}
</style>

