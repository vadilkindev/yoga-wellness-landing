---
import '../../styles/variables.css';
import '../../styles/globals.css';
import Navbar from './Navbar.astro';
import Footer from './Footer.astro';

interface Props {
  title: string;
  description?: string;
}

const { 
  title, 
  description = "Radha - Yoga, Meditacion Zen, Masajes, Reiki"
} = Astro.props;
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <!-- Fonts Import: Cormorant Garamond + Manrope -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=Manrope:wght@300;400;500;600&display=swap" rel="stylesheet">
    <title>{title}</title>
  </head>
  <body>
    <Navbar />
    <main>
      <slot />
    </main>
    <Footer />

    <!-- Global scroll-reveal via IntersectionObserver -->
    <script>
      const revealEls = document.querySelectorAll<HTMLElement>('.reveal-up');

      // Hero elements animate via CSS keyframes — skip them
      const toObserve = Array.from(revealEls).filter(
        el => !el.closest('#hero')
      );

      if ('IntersectionObserver' in window) {
        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach(entry => {
              if (entry.isIntersecting) {
                (entry.target as HTMLElement).classList.add('visible');
                io.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.1 }
        );
        toObserve.forEach(el => io.observe(el));
      } else {
        toObserve.forEach(el => el.classList.add('visible'));
      }
    </script>
  </body>
</html>

