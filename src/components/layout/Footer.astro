---
import { NAV_LINKS } from '../../constants';
import Container from './Container.astro';
import IconWrapper from '../ui/IconWrapper.astro';

const year = new Date().getFullYear();
---

<footer class="footer">
  <Container>
    <div class="footer-grid">
      <div class="footer-brand reveal-up">
        <span class="logo">Radha</span>
        <p class="tagline">Yoga, Bienestar & Life Coaching</p>
      </div>
      
      <div class="footer-links reveal-up reveal-delay-1">
        <h3 class="footer-title">Menú</h3>
        <ul class="link-list">
          {NAV_LINKS.map(link => (
            <li><a href={link.href}>{link.label}</a></li>
          ))}
        </ul>
      </div>

      <div class="footer-social reveal-up reveal-delay-2">
        <h3 class="footer-title">Seguime</h3>
        <div class="social-icons">
          <!-- Simplified Icons -->
          <IconWrapper size="sm" class="custom-icon"><span aria-hidden="true">In</span></IconWrapper>
          <IconWrapper size="sm" class="custom-icon"><span aria-hidden="true">Ig</span></IconWrapper>
          <IconWrapper size="sm" class="custom-icon"><span aria-hidden="true">Fb</span></IconWrapper>
        </div>
      </div>
    </div>
    
    <div class="footer-bottom reveal-up reveal-delay-3">
      <p>&copy; {year} Radha. Todos los derechos reservados.</p>
    </div>
  </Container>
</footer>

<style>
  .footer {
    background-color: var(--color-bg);
    color: var(--color-text-primary);
    padding-block: var(--space-4xl) var(--space-lg);
    border-top: 1px solid var(--color-border);
  }

  .footer-grid {
    display: grid;
    gap: var(--space-3xl);
    grid-template-columns: 1fr;
    border-bottom: 1px solid var(--color-border);
    padding-bottom: var(--space-3xl);
  }

  @media (min-width: 768px) {
    .footer-grid {
      grid-template-columns: 2fr 1fr 1fr;
    }
  }

  .logo {
    display: block;
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    font-weight: 400;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin-bottom: var(--space-sm);
  }

  .tagline {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-style: italic;
    color: var(--color-text-secondary);
  }

  .footer-title {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: var(--space-md);
    color: var(--color-primary);
  }

  .link-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .link-list a {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    transition: color var(--transition-fast);
  }

  .link-list a:hover {
    color: var(--color-primary);
  }

  .social-icons {
    display: flex;
    gap: var(--space-md);
  }
  
  .social-icons :global(.custom-icon) {
    background-color: transparent;
    border: 1px solid var(--color-border);
    color: var(--color-text-primary);
    cursor: pointer;
    transition: all var(--transition-slow);
    border-radius: 50%;
  }

  .social-icons :global(.custom-icon:hover) {
    border-color: var(--color-primary);
    color: var(--color-primary);
    transform: translateY(-2px);
  }

  .footer-bottom {
    padding-top: var(--space-xl);
    text-align: center;
    font-size: var(--text-xs);
    letter-spacing: 0.05em;
    color: var(--color-text-secondary);
  }
</style>
