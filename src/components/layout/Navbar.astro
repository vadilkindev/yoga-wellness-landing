---
import { NAV_LINKS } from '../../constants';
import Button from '../ui/Button.astro';
import Container from './Container.astro';
---

<header class="navbar" id="main-nav">
  <Container>
    <div class="navbar-wrapper">
      <a href="/" class="logo">
        Radha
      </a>

      <!-- Desktop Nav -->
      <nav class="desktop-nav">
        <ul class="nav-list">
          {NAV_LINKS.map((link, index) => (
            <li class={`reveal-up reveal-delay-${index + 1}`}>
              <a href={link.href} class="nav-link">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>

      <!-- CTA -->
      <div class="nav-cta reveal-up reveal-delay-4">
        <Button variant="outline" size="sm" href="#booking">Reservá</Button>
      </div>

      <!-- Mobile Menu Toggle -->
      <button class="mobile-toggle" aria-label="Toggle Menu">
        <span></span>
        <span></span>
      </button>
    </div>
  </Container>
</header>

<style>
  .navbar {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: var(--navbar-height);
    background-color: rgba(250, 248, 245, 0.85); /* Warm off-white with transparency */
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-bottom: 1px solid rgba(45, 43, 42, 0.05); /* Extremely subtle border */
    z-index: 100;
    display: flex;
    align-items: center;
    transition: all var(--transition-medium);
  }

  .navbar-wrapper {
    display: flex;
    justify-content: space-between;
    align-items: center;
    width: 100%;
  }

  .logo {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    font-weight: 400;
    letter-spacing: 0.15em;
    color: var(--color-text-primary);
    text-transform: uppercase;
    animation: revealUp 1s var(--ease-out-expo) forwards;
  }

  .desktop-nav {
    display: none;
  }

  @media (min-width: 768px) {
    .desktop-nav {
      display: block;
    }
  }

  .nav-list {
    display: flex;
    gap: var(--space-xl);
  }

  .nav-link {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-text-secondary);
    position: relative;
    padding-bottom: 4px;
    transition: color var(--transition-fast);
  }

  .nav-link::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0;
    height: 1px;
    background-color: var(--color-primary);
    transition: width var(--transition-slow);
  }

  .nav-link:hover {
    color: var(--color-text-primary);
  }

  .nav-link:hover::after {
    width: 100%;
  }

  .nav-cta {
    display: none;
  }

  @media (min-width: 768px) {
    .nav-cta {
      display: block;
    }
  }

  .mobile-toggle {
    display: flex;
    flex-direction: column;
    gap: 6px;
    background: transparent;
    border: none;
    cursor: pointer;
    padding: var(--space-xs);
  }

  @media (min-width: 768px) {
    .mobile-toggle {
      display: none;
    }
  }

  .mobile-toggle span {
    display: block;
    width: 28px;
    height: 1px;
    background-color: var(--color-text-primary);
    transition: transform var(--transition-slow);
  }
</style>

<script>
  // Soft scroll shadow entry
  const navbar = document.getElementById('main-nav');
  window.addEventListener('scroll', () => {
    if (window.scrollY > 50) {
      navbar?.style.setProperty('box-shadow', 'var(--shadow-sm)');
    } else {
      navbar?.style.setProperty('box-shadow', 'none');
    }
  });
</script>
