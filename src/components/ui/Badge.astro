---
interface Props {
  label: string;
  class?: string;
}

const { label, class: className = '' } = Astro.props;
---
<span class:list={['badge', className]}>
  {label}
</span>

<style>
  .badge {
    display: inline-flex;
    align-items: center;
    padding: 4px 10px;
    background-color: var(--color-primary);
    color: #fff;
    border-radius: var(--radius-full);
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    line-height: 1;
    box-shadow: 0 2px 8px rgba(235, 91, 109, 0.3);
  }
</style>
