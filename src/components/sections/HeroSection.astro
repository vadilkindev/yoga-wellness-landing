---
import Container from '../layout/Container.astro';
import SectionWrapper from '../layout/SectionWrapper.astro';
import Button from '../ui/Button.astro';
---

<SectionWrapper id="hero" class="hero-section" bg="none">
  <div class="hero-bg">
    <!-- Warm, soft gradient mesh effect -->
    <div class="gradient-blob shape-1"></div>
    <div class="gradient-blob shape-2"></div>
    <div class="gradient-blob shape-3"></div>
    <div class="overlay"></div>
  </div>
  
  <Container>
    <div class="hero-content">
      <span class="hero-subtitle reveal-up">Amor & Expansión</span>
      <h1 class="hero-title reveal-up reveal-delay-1">Radha</h1>
      <p class="hero-description reveal-up reveal-delay-2">Yoga, Meditación y Life Coaching para cultivar una vida en equilibrio profundo y conexión consciente.</p>
      
      <div class="hero-actions reveal-up reveal-delay-3">
        <Button href="#booking" size="lg">Reservá tu Lugar</Button>
      </div>

      <div class="hero-keywords reveal-up reveal-delay-4">
        <span>Crecer</span>
        <span class="dot">•</span>
        <span>Fluir</span>
        <span class="dot">•</span>
        <span>Brillar</span>
      </div>
    </div>
  </Container>
</SectionWrapper>

<style>
  .hero-section {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding-top: var(--navbar-height);
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    overflow: hidden;
    z-index: -1;
    background-color: var(--color-bg);
  }

  .gradient-blob {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    opacity: 0.6;
    animation: drift 20s infinite alternate cubic-bezier(0.5, 0, 0.5, 1);
  }

  .shape-1 {
    top: -20%;
    left: -10%;
    width: 60vw;
    height: 60vw;
    background: var(--color-primary); /* Coral */
  }

  .shape-2 {
    bottom: -10%;
    right: -20%;
    width: 70vw;
    height: 70vw;
    background: var(--color-secondary); /* Blush */
    animation-delay: -5s;
  }

  .shape-3 {
    top: 30%;
    left: 40%;
    width: 40vw;
    height: 40vw;
    background: var(--color-accent); /* Dusty Coral */
    opacity: 0.25;
    animation-delay: -10s;
  }

  @keyframes drift {
    0% { transform: translate(0, 0) scale(1); }
    100% { transform: translate(10%, 10%) scale(1.1); }
  }

  .overlay {
    position: absolute;
    inset: 0;
    background: rgba(250, 248, 245, 0.4); /* Slight frosted glass */
    backdrop-filter: blur(40px);
    -webkit-backdrop-filter: blur(40px);
  }

  .hero-content {
    position: relative;
    text-align: center;
    max-width: 800px;
    margin-inline: auto;
    z-index: 1;
  }

  .hero-subtitle {
    display: block;
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    font-style: italic;
    color: var(--color-primary);
    margin-bottom: var(--space-sm);
  }

  .hero-title {
    font-size: clamp(4rem, 12vw, 8rem);
    letter-spacing: 0.05em;
    font-weight: 300;
    margin: 0;
    margin-bottom: var(--space-md);
    color: var(--color-text-primary);
    line-height: 1;
  }

  .hero-description {
    font-size: var(--text-lg);
    color: var(--color-text-secondary);
    margin-bottom: var(--space-2xl);
    max-width: 600px;
    margin-inline: auto;
    font-weight: 300;
  }

  .hero-actions {
    margin-bottom: var(--space-3xl);
  }

  .hero-keywords {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-lg);
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-style: italic;
    color: var(--color-accent);
  }

  .dot {
    font-size: 0.5em;
    color: var(--color-text-secondary);
  }
</style>
