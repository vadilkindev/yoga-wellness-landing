---
import Container from '../layout/Container.astro';
import SectionWrapper from '../layout/SectionWrapper.astro';
import SectionTitle from '../ui/SectionTitle.astro';
import Button from '../ui/Button.astro';
---

<SectionWrapper id="about" bg="muted">
  <Container>
    <div class="about-grid">
      <!-- Image column -->
      <div class="about-image-wrapper reveal-up">
        <div class="image-frame">
          <div class="image-placeholder" aria-hidden="true">
            <span class="placeholder-initials">R</span>
          </div>
          <!-- Floating accent card -->
          <div class="about-stat reveal-up reveal-delay-2">
            <span class="stat-number">+10</span>
            <span class="stat-label">Años de<br/>experiencia</span>
          </div>
        </div>
        <div class="decorative-blob" aria-hidden="true"></div>
      </div>

      <!-- Content column -->
      <div class="about-content reveal-up reveal-delay-1">
        <SectionTitle 
          title="Elevá tu vida" 
          subtitle="Sobre Mí"
          alignment="left"
        />
        
        <div class="prose">
          <p class="drop-cap">
            Bienvenida a Radha. Me dedico a ayudarte a encontrar equilibrio, 
            fuerza y paz interior a través del poder transformador del yoga y la meditación Zen.
          </p>
          <p>
            Con años de experiencia en bienestar holístico, mi enfoque combina prácticas 
            tradicionales con el entendimiento moderno, para acompañarte en tu viaje hacia una 
            vida mucho más sana y vibrante.
          </p>
          <p>
            Ya sea que estés recién arrancando o buscando profundizar en tu práctica, 
            estoy acá para guiarte y apoyarte en cada paso del camino.
          </p>
        </div>

        <div class="about-actions">
          <Button href="#booking" variant="primary">Contactame</Button>
          <Button href="#services" variant="ghost">Ver Servicios</Button>
        </div>
      </div>
    </div>
  </Container>
</SectionWrapper>

<style>
  .about-grid {
    display: grid;
    gap: var(--space-4xl);
    align-items: center;
  }

  @media (min-width: 1024px) {
    .about-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  .about-image-wrapper {
    position: relative;
    width: 100%;
    max-width: 460px;
    margin-inline: auto;
  }

  .image-frame {
    position: relative;
    aspect-ratio: 3/4;
    z-index: 2;
  }

  .image-placeholder {
    width: 100%;
    height: 100%;
    background: linear-gradient(145deg, var(--color-secondary) 0%, var(--color-accent) 100%);
    border-radius: 240px 240px 0 0;
    position: relative;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: var(--shadow-lg);
  }

  .placeholder-initials {
    font-family: var(--font-display);
    font-size: 8rem;
    font-weight: 300;
    color: rgba(255, 255, 255, 0.6);
    user-select: none;
    line-height: 1;
  }

  /* Floating stat badge */
  .about-stat {
    position: absolute;
    bottom: -var(--space-md);
    right: calc(-1 * var(--space-md));
    bottom: -1rem;
    right: -1rem;
    background-color: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-md) var(--space-lg);
    box-shadow: var(--shadow-md);
    text-align: center;
    z-index: 3;
  }

  .stat-number {
    display: block;
    font-family: var(--font-display);
    font-size: var(--text-3xl);
    font-weight: 600;
    color: var(--color-primary);
    line-height: 1;
  }

  .stat-label {
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-secondary);
    margin-top: 4px;
    display: block;
  }

  .decorative-blob {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-60%, -50%);
    width: 85%;
    height: 85%;
    background-color: var(--color-secondary);
    border-radius: 50%;
    opacity: 0.5;
    z-index: 1;
    filter: blur(60px);
  }

  .prose {
    font-size: var(--text-md);
    color: var(--color-text-secondary);
    margin-bottom: var(--space-2xl);
    line-height: 1.8;
  }

  .prose p {
    margin-bottom: var(--space-lg);
  }

  /* Editorial Drop Cap */
  .drop-cap::first-letter {
    font-family: var(--font-display);
    font-size: 3.5em;
    color: var(--color-primary);
    float: left;
    line-height: 0.8;
    padding-right: 8px;
    padding-top: 6px;
  }

  .about-actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-md);
  }
</style>
