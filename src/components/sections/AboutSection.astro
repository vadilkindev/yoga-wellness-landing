---
import Container from '../layout/Container.astro';
import SectionWrapper from '../layout/SectionWrapper.astro';
import SectionTitle from '../ui/SectionTitle.astro';
import Button from '../ui/Button.astro';
---

<SectionWrapper id="about" bg="muted">
  <Container>
    <div class="about-grid">
      <div class="about-image-wrapper reveal-up">
        <!-- Arch-shaped placeholder for image -->
        <div class="image-placeholder">
          <span class="sr-only">Profile photo of the coach</span>
        </div>
        <div class="decorative-blob"></div>
      </div>
      
      <div class="about-content reveal-up reveal-delay-2">
        <SectionTitle 
          title="Elevá tu vida" 
          subtitle="Sobre Mí"
          alignment="left"
        />
        
        <div class="prose">
          <p class="drop-cap">
            Bienvenida a Radha. Me dedico a ayudarte a encontrar equilibrio, 
            fuerza y paz interior a través del poder transformador del yoga y la meditación Zen.
          </p>
          <p>
            Con años de experiencia en bienestar holístico, mi enfoque combina prácticas 
            tradicionales con el entendimiento moderno, para acompañarte en tu viaje hacia una 
            vida mucho más sana y vibrante.
          </p>
          <p>
            Ya sea que estés recién arrancando o buscando profundizar en tu práctica, 
            estoy acá para guiarte y apoyarte en cada paso del camino.
          </p>
        </div>

        <div class="about-actions">
          <Button href="#booking" variant="primary">Contactame</Button>
          <Button href="#services" variant="ghost">Ver Servicios</Button>
        </div>
      </div>
    </div>
  </Container>
</SectionWrapper>

<style>
  .about-grid {
    display: grid;
    gap: var(--space-4xl);
    align-items: center;
  }

  @media (min-width: 1024px) {
    .about-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  .about-image-wrapper {
    position: relative;
    width: 100%;
    aspect-ratio: 3/4;
    max-width: 450px;
    margin-inline: auto;
  }

  .image-placeholder {
    width: 100%;
    height: 100%;
    background-color: var(--color-bg);
    border: 1px solid var(--color-border);
    /* Classic arch window shape */
    border-radius: 200px 200px 0 0;
    position: relative;
    z-index: 2;
    overflow: hidden;
  }

  /* Just for visual effect in absence of real image */
  .image-placeholder::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, transparent, rgba(163, 140, 113, 0.1));
  }

  .decorative-blob {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 80%;
    height: 80%;
    background-color: var(--color-secondary);
    border-radius: 50%;
    opacity: 0.5;
    z-index: 1;
    filter: blur(60px);
  }

  .prose {
    font-size: var(--text-md);
    color: var(--color-text-secondary);
    margin-bottom: var(--space-2xl);
    line-height: 1.8;
  }

  .prose p {
    margin-bottom: var(--space-lg);
  }

  /* Editorial Drop Cap */
  .drop-cap::first-letter {
    font-family: var(--font-display);
    font-size: 3.5em;
    color: var(--color-primary);
    float: left;
    line-height: 0.8;
    padding-right: 8px;
    padding-top: 6px;
  }

  .about-actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-md);
  }
</style>
