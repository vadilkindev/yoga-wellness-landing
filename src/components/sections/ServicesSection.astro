---
import { SERVICES } from '../../constants';
import Container from '../layout/Container.astro';
import SectionWrapper from '../layout/SectionWrapper.astro';
import SectionTitle from '../ui/SectionTitle.astro';
import Card from '../ui/Card.astro';
import Button from '../ui/Button.astro';
import IconWrapper from '../ui/IconWrapper.astro';
---

<SectionWrapper id="services" bg="white">
  <Container>
    <SectionTitle 
      title="Nuestro Espacio" 
      subtitle="Servicios"
    />
    
    <div class="services-grid">
      {SERVICES.map((service, index) => (
        <div class={`service-wrapper reveal-up reveal-delay-${(index % 4) + 1}`}>
          <Card interactive class="service-card">
            <div class="card-content">
              <IconWrapper size="lg" class="service-icon">
                {service.icon}
              </IconWrapper>
              <h3 class="service-title">{service.title}</h3>
              <p class="service-description">{service.description}</p>
            </div>
            <div class="card-action">
              <Button variant="outline" href="#booking" class="service-btn">Reservá</Button>
            </div>
          </Card>
        </div>
      ))}
    </div>
  </Container>
</SectionWrapper>

<style>
  .services-grid {
    display: grid;
    gap: var(--space-xl);
    grid-template-columns: 1fr;
  }

  @media (min-width: 640px) {
    .services-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-2xl);
    }
  }

  .service-wrapper {
    height: 100%;
  }

  .service-card {
    text-align: center;
    justify-content: space-between;
    background-color: var(--color-bg);
    border-radius: var(--radius-md);
    transition: all var(--transition-medium);
  }

  .service-card:hover {
    box-shadow: var(--shadow-md);
    border-color: var(--color-accent);
    transform: translateY(-4px);
  }

  .card-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    margin-bottom: var(--space-xl);
  }

  .service-icon {
    margin-bottom: var(--space-lg);
    background-color: var(--color-secondary);
    border: 1px solid var(--color-border);
    color: var(--color-primary);
    font-size: 1.75rem;
    transition: all var(--transition-medium);
    border-radius: var(--radius-lg);
  }

  /* Card hover state affects child icon */
  :global(.card.interactive:hover) .service-icon {
    background-color: var(--color-primary);
    border-color: var(--color-primary);
    color: #fff;
    transform: scale(1.08);
  }

  .service-title {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    font-weight: 400;
    letter-spacing: 0.05em;
    margin-bottom: var(--space-sm);
    text-align: center;
    color: var(--color-text-primary);
  }

  .service-description {
    color: var(--color-text-secondary);
    text-align: center;
    font-size: var(--text-sm);
    line-height: 1.7;
  }
  
  .card-action {
    margin-top: auto;
  }

  .service-btn {
    width: 100%;
  }
</style>
