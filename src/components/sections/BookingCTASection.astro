---
import Container from '../layout/Container.astro';
import SectionWrapper from '../layout/SectionWrapper.astro';
import SectionTitle from '../ui/SectionTitle.astro';
import Button from '../ui/Button.astro';
import Input from '../ui/Input.astro';
---

<SectionWrapper id="booking" bg="muted">
  <Container>
    <div class="booking-container reveal-up">
      <div class="booking-content">
        <SectionTitle 
          title="Reservá una Sesión" 
          subtitle="¿Lista para arrancar?"
        />
        <p class="booking-description">
          Ya sea que busques clases privadas, retiros o coaching personalizado, 
          encontremos el momento ideal para conectar. Llená el formulario acá abajo.
        </p>
      </div>

      <div class="booking-form-wrapper">
        <form class="booking-form" onsubmit="event.preventDefault();">
          <div class="form-row">
            <Input name="firstName" placeholder="Nombre" required />
            <Input name="lastName" placeholder="Apellido" required />
          </div>
          <Input type="email" name="email" placeholder="Correo Electrónico" required />
          <Input type="tel" name="phone" placeholder="Número de Celular" />
          
          <div class="select-wrapper">
            <select name="service" required class="select-input">
              <option value="" disabled selected>Seleccioná un Servicio</option>
              <option value="yoga-class">Clase de Yoga</option>
              <option value="yoga-retreat">Retiro de Yoga</option>
              <option value="meditation">Sesión de Meditación</option>
              <option value="coaching">Coaching Personal</option>
            </select>
          </div>
          
          <Button type="submit" size="lg" class="submit-btn" variant="primary">Solicitar Reserva</Button>
        </form>
      </div>
    </div>
  </Container>
</SectionWrapper>

<style>
  .booking-container {
    max-width: 800px;
    margin-inline: auto;
    background-color: var(--color-bg);
    border: 1px solid var(--color-border); /* Flat, no shadow */
    border-radius: var(--radius-sm);
    overflow: hidden;
  }

  .booking-content {
    padding: var(--space-3xl) var(--space-xl) var(--space-xl);
    text-align: center;
    background: linear-gradient(135deg, var(--color-primary) 0%, #c44d5e 100%);
    color: var(--color-bg);
  }

  @media (min-width: 640px) {
    .booking-content {
      padding: var(--space-3xl) var(--space-2xl) var(--space-2xl);
    }
  }

  .booking-content :global(.title), 
  .booking-content :global(.subtitle) {
    color: var(--color-bg) !important;
  }

  .booking-content :global(.subtitle::before),
  .booking-content :global(.subtitle::after) {
    background-color: var(--color-bg) !important;
  }

  .booking-description {
    font-size: var(--text-md);
    color: rgba(255, 255, 255, 0.85); /* Slightly muted white */
    max-width: 600px;
    margin-inline: auto;
    line-height: 1.7;
    margin-top: calc(-1 * var(--space-lg)); /* Pull up closer to title */
  }

  .booking-form-wrapper {
    padding: var(--space-2xl) var(--space-xl);
  }

  .booking-form {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .form-row {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  @media (min-width: 640px) {
    .form-row {
      flex-direction: row;
    }
  }

  .select-wrapper {
    position: relative;
  }

  .select-input {
    width: 100%;
    padding: var(--space-sm) var(--space-md);
    background-color: transparent;
    border: none;
    border-bottom: 1.5px solid var(--color-border);
    border-radius: 0;
    font-family: var(--font-body);
    font-size: var(--text-base);
    color: var(--color-text-primary);
    appearance: none;
    -webkit-appearance: none;
    cursor: pointer;
    transition: border-color var(--transition-fast);
  }

  .select-input:focus {
    outline: none;
    border-color: var(--color-primary);
    box-shadow: 0 2px 0 0 rgba(235, 91, 109, 0.18);
  }

  .select-wrapper::after {
    content: '▾';
    font-size: 0.85em;
    position: absolute;
    right: var(--space-sm);
    top: 50%;
    transform: translateY(-50%);
    pointer-events: none;
    color: var(--color-text-secondary);
  }

  .submit-btn {
    margin-top: var(--space-xl);
    width: 100%;
  }

  @media (min-width: 640px) {
    .booking-form-wrapper {
      padding: var(--space-2xl) var(--space-2xl) var(--space-2xl);
    }
  }
</style>
