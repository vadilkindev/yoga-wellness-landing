---
import { FEATURES } from '../../constants';
import Container from '../layout/Container.astro';
import SectionWrapper from '../layout/SectionWrapper.astro';
---

<SectionWrapper id="features" bg="muted">
  <Container>
    <div class="features-wrapper">
      <div class="features-header reveal-up">
        <h2 class="features-title">
          "El verdadero viaje es descubrirte a vos misma."
        </h2>
        <div class="decorative-line"></div>
      </div>

      <div class="features-list">
        {FEATURES.map((feature, index) => (
          <div class={`feature-item reveal-up reveal-delay-${(index % 3) + 1}`}>
            <span class="feature-number">0{index + 1}</span>
            <div class="feature-content">
              <h3 class="item-title">{feature.title}</h3>
              <p class="item-description">{feature.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </Container>
</SectionWrapper>

<style>
  .features-wrapper {
    display: flex;
    flex-direction: column;
    gap: var(--space-4xl);
    text-align: left; /* Force left alignment */
  }

  @media (min-width: 1024px) {
    .features-wrapper {
      flex-direction: row;
      align-items: flex-start;
      gap: var(--space-4xl);
    }
  }

  .features-header {
    flex: 1;
    position: sticky;
    top: calc(var(--navbar-height) + var(--space-xl));
  }

  .features-title {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-style: italic;
    font-weight: 300;
    line-height: 1.1;
    color: var(--color-text-primary); /* Dark espresso instead of coral to ensure legibility */
    margin-bottom: var(--space-lg);
  }

  .decorative-line {
    width: 60px;
    height: 1px;
    background-color: var(--color-primary); /* Coral accent line */
  }

  .features-list {
    flex: 1.5;
    display: flex;
    flex-direction: column;
    gap: var(--space-4xl);
  }

  .feature-item {
    display: flex;
    flex-direction: column; /* Better for mobile */
    gap: var(--space-md);
    position: relative;
    padding-bottom: var(--space-xl);
    border-bottom: 1px solid var(--color-border);
  }
  
  @media (min-width: 640px) {
    .feature-item {
      flex-direction: row;
      gap: var(--space-lg);
    }
  }

  .feature-item:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .feature-number {
    font-family: var(--font-display);
    font-size: var(--text-5xl);
    font-style: italic;
    color: var(--color-primary); /* Coral to pop! */
    line-height: 0.8;
    user-select: none;
    font-weight: 600;
  }

  .feature-content {
    flex: 1;
    padding-top: var(--space-sm);
  }

  .item-title {
    font-family: var(--font-body);
    font-size: var(--text-lg);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-primary); /* Strict Dark Espresso */
    margin-bottom: var(--space-sm);
  }

  .item-description {
    color: var(--color-text-secondary); /* Strict Dark Grey */
    font-size: var(--text-base);
    line-height: 1.8;
  }
</style>
